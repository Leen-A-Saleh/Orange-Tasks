@model Student
<!DOCTYPE html>
    <html>
    <head>
        <title>Add student</title>
    </head>
    <body>
        <h1>Add Student</h1>
    <form method="post" action="/Students/Create">
        <div class="mb-3">
            <label for="exampleInputName" class="form-label">Student Name</label>
            <input type="text" class="form-control" name="Name" value="@Model.Name" id="exampleInputName" aria-describedby="name">
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label for="exampleInputEmail1" class="form-label">Student Email</label>
            <input type="email" class="form-control" name="Email" value="@Model.Email" id="exampleInputEmail1" aria-describedby="emailHelp">
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="mb-3 form-check">
            <input type="radio" class="form-check-input" asp-for="Gender" value="0" id="genderM">
            <label class="form-check-label" for="genderM">Male</label>
        </div>
        <div class="mb-3 form-check">
            <input type="radio" class="form-check-input" asp-for="Gender" value="1" id="genderF">
            <label class="form-check-label" for="genderF">Female</label>
        </div>

        <button type="submit" class="btn btn-primary">Add</button>
    </form>
    </body>
    </html>
